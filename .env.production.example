# 이 파일을 복사해서 .env.production 으로 만들고 실제 값을 채워넣으세요.
# .env.production 은 절대 git에 커밋하지 마세요.

PORT=3000
NODE_ENV=production

# PostgreSQL (DB_HOST, REDIS_HOST는 docker-compose가 자동 주입)
DB_PORT=5432
DB_NAME=autocare
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# RAG
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.5
CACHE_TTL_SECONDS=300
